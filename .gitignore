# Superpowers tooling state
.superpowers/

# Session-local planning / backlog / todo scratchpads — private to the
# working repo, not meant for public GitHub. Previously-tracked files
# are untracked via `git rm --cached` alongside this change; they stay
# on disk for local reference.
docs/superpowers/
SCAFFOLD_TODOS.md

# Git worktrees
.worktrees/

# Rust build output
target/

# Distribution artifacts
dist/

# Environment files
.env
.env.local
*.env

# Editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Go build artifacts (tui/)
tui/stui
tui/*.test
tui/*.out
tui/coverage.html
tui/vendor/
tui/go.work
tui/go.work.sum

# Runtime socket / lock files
*.sock
*.pid

# Project-owned TVDB API key — baked into the binary by runtime/build.rs.
# Keep OUT of git; set TVDB_API_KEY in CI env for release builds or drop the
# key into one of these files locally.
runtime/.tvdb-key
.tvdb-key

# Compiled plugin artifacts
plugins/**/target/
plugins/**/*.so
plugins/**/*.dll
plugins/**/*.dylib
# Dev-install symlinks produced by smoke-testing (stui plugin install --dev
# expects a plugin.wasm next to plugin.toml; we symlink target/.../*.wasm in,
# which should never land in git).
plugins/**/plugin.wasm
